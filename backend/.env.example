# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Application Mode
MODE=mock

# Adapter Mode
ADAPTER_MODE=mock

# Flask Secret Key
SECRET_KEY=your-secret-key-here

# Model Directory
MODEL_DIR=models
