# Root level gitignore
# Specific gitignores exist in backend/ and frontend/

# Environment files
.env
.env.local
.env.*.local
.env.production
.env.development

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Temporary files
*.tmp
*.temp

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv

# Node modules
node_modules/

# Build outputs
dist/
build/

# Test artifacts
.pytest_cache/
.hypothesis/

# Sensitive data (just in case)
*.pem
*.key
*.cert
*secret*
*credentials*
